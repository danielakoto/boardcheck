{
  "manifest_version": 3,
  "name": "BoardCheck - The simple keyboard checker.",
  "version": "1.0",
  "key": "gnmdeencleiabgilnbbgiefcmclnpdoj",
  "description": "The most satisfying keyboard checker chrome extension.",
  "icons": {
    "16": "img/logo-128.png",
    "48": "img/logo-128.png",
    "128": "img/logo-128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "img/logo-128.png",
      "48": "img/logo-128.png",
      "128": "img/logo-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "permissions": ["storage", "activeTab", "scripting", "identity"],
  "host_permissions": [
    "<all_urls>"
  ],
  "oauth2": {
    "client_id": "91837916881-a4te4jthb482m1p0c331ul54g886k9dd.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },
  "web_accessible_resources": [
    {
      "resources": ["sounds/keyboard/*.mp3", "img/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}